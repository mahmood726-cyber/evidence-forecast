<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Evidence Forecast — {{ card.pico_id }}</title>
<style>
body { font-family: system-ui, sans-serif; max-width: 820px; margin: 2em auto; padding: 0 1em; color: #222; }
h1 { font-size: 1.4em; border-bottom: 2px solid #444; padding-bottom: .3em; }
.card { display: grid; grid-template-columns: 1fr 1fr; gap: 1em; margin-top: 1em; }
.panel { border: 1px solid #ccc; border-radius: 6px; padding: 1em; background: #fafafa; }
.panel h2 { margin: 0 0 .4em 0; font-size: 1.05em; color: #333; }
.big { font-size: 1.8em; font-weight: 600; color: #111; }
.muted { color: #666; font-size: .85em; }
footer { margin-top: 2em; font-size: .75em; color: #777; border-top: 1px solid #ddd; padding-top: .6em; word-break: break-all; }
</style>
</head>
<body>
<h1>Evidence Forecast — {{ card.pico_id }}</h1>
<p class="muted">Generated {{ card.generated_utc }} · schema v{{ card.schema_version }}</p>

<div class="card">
  <div class="panel">
    <h2>Current effect</h2>
    <div class="big">{{ "%.2f"|format(card.effect.point) }} {{ card.effect.scale }}</div>
    <div class="muted">95% CI {{ "%.2f"|format(card.effect.ci_low) }}–{{ "%.2f"|format(card.effect.ci_high) }} · k={{ card.effect.k }} · I²={{ (card.effect.i2 * 100)|round|int }}%</div>
  </div>
  <div class="panel">
    <h2>Flip probability ({{ card.flip.horizon_months }}-month horizon)</h2>
    <div class="big">{{ (card.flip.probability * 100)|round|int }}%</div>
    <div class="muted">95% CI {{ (card.flip.ci_low * 100)|round|int }}%–{{ (card.flip.ci_high * 100)|round|int }}%{% if card.flip.pipeline_empty %} · <strong>pipeline empty</strong>{% endif %}</div>
  </div>
  <div class="panel">
    <h2>Representativeness</h2>
    <div class="big">{{ (card.representativeness.overlap_score * 100)|round|int }}%</div>
    <div class="muted">{{ card.representativeness.trial_country_count }} trial countries · source: {{ card.representativeness.source }}</div>
  </div>
  <div class="panel">
    <h2>TruthCert</h2>
    <div class="muted">sha256</div>
    <div style="font-family: monospace; font-size: .75em; word-break: break-all;">{{ card.truthcert.sha256 }}</div>
    <div class="muted" style="margin-top:.4em;">signed {{ card.truthcert.signed_utc }}</div>
  </div>
</div>
<footer>
  Evidence Forecast v{{ card.schema_version }} · HMAC: {{ card.truthcert.hmac_sha256[:32] }}…
</footer>
</body>
</html>
